{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/trade", "schedule": "32 13 * * 1-5" },
    { "path": "/api/trade", "schedule": "32 14 * * 1-5" },
    { "path": "/api/trade?action=close", "schedule": "59 19 * * 1-5" },
    { "path": "/api/trade?action=close", "schedule": "59 20 * * 1-5" }
  ],
  "functions": {
    "api/trade.js": { "maxDuration": 60 }
  }
}
